# Salin file ini jadi ".env" lalu isi sesuai database MySQL kamu.
# JANGAN commit file ".env" (yang sudah diisi) ke Git — cukup file ".env.example" ini.

# Alamat host database MySQL kamu.
# Isi dengan alamat database remote (BUKAN localhost) kalau mau bisa diakses
# dari luar laptop kamu sendiri, misalnya dari layanan hosting MySQL seperti
# Railway, Aiven, Clever Cloud, PlanetScale (MySQL-compatible), dll.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=absen_wfh

# Beberapa layanan hosting MySQL mewajibkan koneksi SSL. Set "true" kalau perlu.
DB_SSL=false

# Kunci buat login ke dashboard admin (/admin) — ganti dengan nilai rahasia sendiri.
ADMIN_KEY=admin123

# Port server Node ini sendiri (bukan port database).
PORT=3000